{% extends 'base.html.twig' %}
{% block title %}
	New Priority
{% endblock %}
{% block body %}
	<div class="h-screen bg-gray-100 flex items-center justify-center">
		<div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-lg">
			{{ form_start(form) }}

			<div class="flex justify-between items-start mb-1">
				<h1 class="text-2xl font-bold">Gérer les Priorités</h1>
				<a href="{{ path('app_home') }}" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</a>
			</div>

			<p class="text-sm text-gray-400 mb-6">Ajoutez ou supprimez des niveaux de priorité personnalisés</p>

			{{ form_label(form.name, 'Nom de la priorité', { label_attr: {class: 'block text-sm font-medium text-gray-700 mb-2'} }) }}
			<div class="flex gap-3 mb-6">
				{{ form_widget(form.name, {
                attr: {class: 'flex-1 h-11 border border-gray-300 rounded-lg px-4 text-sm', placeholder: 'Ex: critique, faible...'}
            }) }}
				<button class="bg-black h-11 w-11 text-white text-xl rounded-lg" type="submit">+</button>
			</div>

			<p class="text-sm font-medium text-gray-700 mb-3">Priorités existantes</p>
			{% for priority in priorities %}
				<div class="w-full h-11 border border-gray-300 rounded-lg px-4 mb-2 flex justify-center items-center text-sm text-gray-700">
					{{ priority.name }}
				</div>
			{% endfor %}

			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
