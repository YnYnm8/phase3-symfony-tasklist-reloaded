{% extends 'base.html.twig' %}

{% block title %}
    Log in!
{% endblock %}

{% block body %}
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}
        <div class= "min-h-screen bg-[#E0E7FF] flex items-center justify-center">

            <div class="bg-white rounded-xl border border-black/10 shadow p-8 w-full max-w-md">
                <h1 class="text-base mb-4">Gestion de Tâche</h1>
                <p class ="text-gray-600">Organisez votre journée efficacement</p>
                {# {{-- タブ（見た目だけ） --}} #}
                <div class="flex rounded-full bg-gray-100 p-1 mb-6">
                    <a href="{{ path('app_login') }}" class="flex-1 text-center py-1 rounded-full text-sm text-gray-500 hover:bg-white">
                        Connexion
                    </a>
                    <span class="flex-1 text-center py-1 rounded-full text-sm bg-white font-semibold shadow-sm">
                        Inscription
                    </span>
                </div>
                <div class= "flex">
                    <div class= "flex-col">

                        <label for="username">Email</label>
                        <div class = "w-[398px] h-9 bg-[#F3F3F5] rounded gap-2">
        

                            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" placeholder="votre@email.com" required autofocus>
                        </div>


                            <label for="password">Mot de passe</label>
                        <div class = "w-[398px] h-9 bg-[#F3F3F5] rounded
                        gap-2">
                            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" placeholder="..........."required>
                            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                        </div>
                        {#
                        Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                        See https://symfony.com/doc/current/security/remember_me.html

                        <div class="checkbox mb-3">
                        <input type="checkbox" name="_remember_me" id="_remember_me">
                        <label for="_remember_me">Remember me</label>
                        </div>
                        #}

                        <button class="btn btn-lg btn-primary bg-black text-white w-[398px] h-9 mt-5 rounded" type="submit">
                            Se connecter
                        </button>
                    </div>

                </div>
            </div>
        </form>
    {% endblock %}
